# ============================================
# MYSTIC PAWS — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mystic_paws?schema=public"

# NextAuth / Auth.js
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# AI Provider - Choose ONE (at least one required for readings)
# Option 1: OpenAI (https://platform.openai.com/api-keys) - $5 free credit for new accounts
OPENAI_API_KEY="sk-proj-..."
# Option 2: OpenRouter (https://openrouter.ai/keys) - Has free models available
# OPENROUTER_API_KEY="sk-or-..."
# Option 3: Anthropic (https://console.anthropic.com) - Paid only
# ANTHROPIC_API_KEY="sk-ant-..."

# Paytm — https://dashboard.paytm.com
PAYTM_MID="your-paytm-merchant-id"
PAYTM_MERCHANT_KEY="your-paytm-merchant-key"
PAYTM_WEBSITE="WEBSTAGING"
PAYTM_CHANNEL_ID="WEB"
PAYTM_INDUSTRY_TYPE_ID="Retail"
PAYTM_CALLBACK_URL="http://localhost:3000/api/payment/callback"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="919999999999"
ADMIN_EMAIL="admin@yourdomain.com"
